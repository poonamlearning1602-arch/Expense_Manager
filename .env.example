# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=sqlite:///expense_manager.db
# For PostgreSQL: postgresql://user:password@localhost/expense_manager
# For MySQL: mysql://user:password@localhost/expense_manager

# API Configuration
API_PORT=5000
API_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO

# Optional: External Services
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password

# Optional: AWS/Cloud Services
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
